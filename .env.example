# Copy to .env and fill in real values. NEVER commit .env (it is gitignored).
# Generate a Django key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Generate a password:   python -c "import secrets; print(secrets.token_urlsafe(48))"

# Database Credentials (used by db service and passed to web service)
MYSQL_DATABASE=annotate_db
MYSQL_USER=annotate_user
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me

# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
